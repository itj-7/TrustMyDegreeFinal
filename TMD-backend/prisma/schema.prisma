generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}
datasource db {
  provider = "postgresql"
 
}

model User {
  id           String        @id @default(uuid())
  fullName     String?
  matricule    String?       @unique
  email        String?       @unique
  password     String
  role         Role          @default(STUDENT)
  dateOfBirth  String?
  placeOfBirth String?
  year         String?
  isGraduated  Boolean       @default(false)
  avatar       String?
  blockchainRegistered Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  certificates Certificate[]
  requests     Request[]
}

model Certificate {
  id               String         @id @default(uuid())
  studentId        String
  uniqueCode       String         @unique
  type             String?
  specialty        String?
  status           CertStatus     @default(ACTIVE)
  issueDate        DateTime       @default(now())
  ipfsHash         String?
  blockchainCertId String?
  contractType     String?
  student          User           @relation(fields: [studentId], references: [id])
  verifications    Verification[]
}

model Request {
  id           String        @id @default(uuid())
  studentId    String
  documentType String
  reason       String
  delivery     String
  priority     Priority      @default(NORMAL)
  status       RequestStatus @default(PENDING)
  ipfsHash     String?
  blockchainDocId String?
  fileUrl      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  student      User          @relation(fields: [studentId], references: [id])
}

model Verification {
  id            String      @id @default(uuid())
  certificateId String
  verifiedAt    DateTime    @default(now())
  ipAddress     String?
  certificate   Certificate @relation(fields: [certificateId], references: [id])
}

model Contact {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String?
  institution  String?
  message      String
  agreedToPolicy Boolean @default(false)
  createdAt    DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STUDENT
}

enum CertStatus {
  ACTIVE
  REVOKED
}

enum Priority {
  URGENT
  NORMAL
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}